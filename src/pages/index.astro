---
import Layout from '~/layouts/Layout.astro';
import Vectorizer from '~/components/Vectorizer.svelte';
---

<Layout>
  <main>
    <header class="hero">
      <h1>vectorize</h1>
      <p class="tagline">
        Convert PNG, JPG, WebP to clean SVG — in your browser. No upload, no signup, open source.
      </p>
    </header>

    <Vectorizer client:only="svelte" />

    <footer>
      <p class="meta">
        <a href="https://github.com/CVERInc/vectorize" rel="noopener">GitHub</a>
        <span class="sep">·</span>
        <span>MIT</span>
        <span class="sep">·</span>
        <span>Powered by <a href="https://github.com/visioncortex/vtracer" rel="noopener">VTracer</a> (WASM)</span>
      </p>
      <p>
        Built by <a href="https://cver.net" rel="noopener">CVER Inc.</a>
      </p>
    </footer>
  </main>
</Layout>

<style>
  main {
    max-width: 1200px;
    margin: 0 auto;
    padding: 2rem 1.25rem 3rem;
  }
  .hero {
    text-align: center;
    margin-bottom: 1.75rem;
  }
  h1 {
    font-size: 2.5rem;
    font-weight: 700;
    margin: 0 0 0.5rem;
    letter-spacing: -0.02em;
  }
  .tagline {
    color: var(--muted);
    font-size: 1.0625rem;
    margin: 0;
  }
  .sep {
    color: var(--border);
  }
  footer {
    margin-top: 4rem;
    text-align: center;
    font-size: 0.875rem;
    color: var(--muted);
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }
  footer p {
    margin: 0;
  }
  footer .meta {
    display: flex;
    justify-content: center;
    gap: 0.5rem;
    flex-wrap: wrap;
  }
</style>
