---
import NavViewSwitch from '~/components/NavViewSwitch.svelte';
import LanguageSwitcher from '~/components/LanguageSwitcher.svelte';

interface Props {
  title?: string;
  description?: string;
}

const {
  title = 'markmint — turn images into clean SVG logos & icons',
  description = 'Turn PNG, JPG, WebP into clean, recolorable SVG logos and icons — in your browser. Open source, MIT-licensed, no upload required.',
} = Astro.props;

const base = import.meta.env.BASE_URL.replace(/\/$/, '');
// CVER logo as favicon — consistent across all cver.net OSS pages.
const iconSmall = `${base}/cver-logo-small.png`;
const iconLarge = `${base}/cver-logo.png`;
const repo = 'https://github.com/CVERInc/markmint';
const siteOrigin = 'https://oss.cver.net';
const ogImage = `${siteOrigin}${base}/og.svg`;
const ogUrl = `${siteOrigin}${base}/`;
const canonical = ogUrl;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1, viewport-fit=cover" />
    <meta name="generator" content={Astro.generator} />
    {/* bleedblend/auto — zero-config Safari chrome tinting (status bar + URL bar) */}
    <script>import 'bleedblend/auto';</script>
    <meta name="description" content={description} />
    <title>{title}</title>
    <link rel="canonical" href={canonical} />
    <link rel="icon" type="image/png" sizes="100x100" href={iconSmall} />
    <link rel="icon" type="image/png" sizes="630x630" href={iconLarge} />
    <link rel="apple-touch-icon" href={iconLarge} />
    <link rel="manifest" href={`${base}/site.webmanifest`} />
    <meta name="theme-color" content="#052829" />

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content="markmint" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={ogUrl} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />

    <!-- Twitter -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />

    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Comfortaa:wght@400;600;700&family=Nunito:ital,wght@0,300;0,400;0,600;0,700;1,300;1,400&display=swap" rel="stylesheet">
  </head>
  <body>
    <header class="site-header">
      <a href="https://cver.net/oss/markmint" class="brand">
        <span class="brand-name">markmint</span>
        <span class="brand-badge">by cver.net</span>
      </a>
      <div class="nav-center">
        <NavViewSwitch client:only="svelte" />
      </div>
      <div class="nav-right">
        <LanguageSwitcher client:only="svelte" />
        <a href={repo} class="gh-link" target="_blank" rel="noopener" aria-label="GitHub repository">
          <svg viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"/></svg>
          <span>GitHub</span>
        </a>
      </div>
    </header>

    <slot />

    <script is:inline define:vars={{ swPath: `${base}/sw.js` }}>
      if ('serviceWorker' in navigator) {
        window.addEventListener('load', () => {
          navigator.serviceWorker.register(swPath).catch(() => {});
        });
      }
    </script>

    <footer class="site-footer">
      <div class="footer-links">
        <a href="https://cver.net/legal/terms" class="link-underline" target="_blank" rel="noopener">Terms of Service</a>
        <span class="footer-sep" aria-hidden="true">|</span>
        <a href="https://cver.net/legal/privacy" class="link-underline" target="_blank" rel="noopener">Privacy Policy</a>
        <span class="footer-sep" aria-hidden="true">|</span>
        <a href="https://cver.net/contact" class="link-underline" target="_blank" rel="noopener">Contact Us</a>
      </div>

      <a href="https://cver.net/" class="footer-logo" target="_blank" rel="noopener" aria-label="CVER Inc.">
        <img src="https://cver.net/cver-logo-small.png" alt="CVER" width="48" height="48" draggable="false" />
      </a>

      <div class="footer-links secondary">
        <a href="https://cver.net/about" class="link-underline" target="_blank" rel="noopener">CVER.NET © 2011–2026 CVER Inc.</a>
        <span class="footer-sep" aria-hidden="true">|</span>
        <a href={`${repo}/blob/main/LICENSE`} class="link-underline" target="_blank" rel="noopener">MIT License</a>
        <span class="footer-sep" aria-hidden="true">|</span>
        <a href="https://github.com/visioncortex/vtracer" class="link-underline" target="_blank" rel="noopener">Powered by VTracer (WASM)</a>
      </div>
    </footer>

    <style is:global>
      :root {
        --bg: #052829;
        --surface: rgba(255, 255, 255, 0.05);
        --text: #f5fbfa;
        --muted: rgba(245, 251, 250, 0.6);
        --border: rgba(255, 255, 255, 0.1);
        --accent: #aceace;
        --accent-hover: #4fd1ca;
        --accent-fg: #084a4c;
        --accent-bg: rgba(172, 234, 206, 0.15);
        --font-sans: 'Nunito', 'Comfortaa', system-ui, -apple-system, sans-serif;
        --font-mono: ui-monospace, 'SF Mono', Menlo, Consolas, monospace;
      }
      *,
      *::before,
      *::after {
        box-sizing: border-box;
      }
      html,
      body {
        margin: 0;
        padding: 0;
        min-height: 100vh;
      }
      body {
        font-family: var(--font-sans);
        color: var(--text);
        -webkit-font-smoothing: antialiased;
        line-height: 1.5;
        position: relative;
        z-index: 0;
        display: flex;
        flex-direction: column;
        min-height: 100vh;
      }
      body > main {
        flex: 1 0 auto;
      }
      body::before {
        content: "";
        position: fixed;
        inset: 0;
        z-index: -1;
        background:
          radial-gradient(circle at 10% 20%, rgba(10, 140, 142, 0.15) 0%, transparent 40%),
          radial-gradient(circle at 90% 80%, rgba(226, 114, 91, 0.15) 0%, transparent 40%),
          #052829;
        background-size: 100% 100%;
      }
      a {
        color: var(--accent);
        text-decoration: none;
      }
      a:hover {
        text-decoration: underline;
      }
      code,
      kbd {
        font-family: var(--font-mono);
        font-size: 0.875em;
        background: rgba(255, 255, 255, 0.1);
        padding: 0.125rem 0.375rem;
        border-radius: 4px;
        border: 1px solid var(--border);
      }
      
      /* Glassmorphic Panel Styles */
      .glass {
        background: rgba(255, 255, 255, 0.08);
        backdrop-filter: blur(10px);
        -webkit-backdrop-filter: blur(10px);
        border: 1px solid rgba(255, 255, 255, 0.12);
        box-shadow: 0 4px 30px rgba(0, 0, 0, 0.1);
      }
      
      a.glass {
        transition: background 200ms ease, border-color 200ms ease;
      }
      
      a.glass:hover {
        background: rgba(255, 255, 255, 0.14);
        border-color: rgba(255, 255, 255, 0.2);
      }

      /* Keyboard focus */
      :focus-visible {
        outline: 2px solid var(--accent-hover);
        outline-offset: 2px;
      }

      /* ── Site header ──────────────────────────────────────────── */
      .site-header {
        display: grid;
        grid-template-columns: 1fr auto 1fr;
        align-items: center;
        gap: 1rem;
        padding: 1.5rem 2.5rem;
        border-bottom: 1px solid var(--border);
        backdrop-filter: blur(10px);
        -webkit-backdrop-filter: blur(10px);
      }
      .nav-center {
        display: flex;
        justify-content: center;
      }
      .nav-right {
        display: flex;
        align-items: center;
        justify-content: flex-end;
        gap: 0.75rem;
      }
      @media (max-width: 720px) {
        .site-header {
          grid-template-columns: auto 1fr;
          row-gap: 0.75rem;
        }
        /* switch drops to a full-width second row, centered */
        .nav-center {
          grid-column: 1 / -1;
          order: 3;
        }
      }
      .brand {
        display: flex;
        align-items: center;
        gap: 0.75rem;
        text-decoration: none;
        color: var(--text);
      }
      .brand:hover { text-decoration: none; }
      .brand-name {
        font-family: 'Comfortaa', var(--font-sans);
        font-size: 1.4rem;
        font-weight: 700;
        letter-spacing: -0.02em;
      }
      .brand-badge {
        font-family: 'Comfortaa', var(--font-sans);
        background: linear-gradient(135deg, var(--accent), var(--accent-hover));
        color: var(--accent-fg);
        font-weight: 700;
        font-size: 0.8rem;
        padding: 0.25rem 0.7rem;
        border-radius: 9999px;
        box-shadow: 0 4px 15px color-mix(in srgb, var(--accent) 35%, transparent);
      }
      .gh-link {
        display: inline-flex;
        align-items: center;
        gap: 0.5rem;
        color: var(--text);
        text-decoration: none;
        font-weight: 600;
        font-size: 0.9rem;
        padding: 0.5rem 1rem;
        border-radius: 8px;
        background: rgba(255, 255, 255, 0.05);
        border: 1px solid var(--border);
        transition: background 0.2s ease, border-color 0.2s ease;
      }
      .gh-link:hover {
        background: rgba(255, 255, 255, 0.1);
        border-color: var(--accent);
        text-decoration: none;
      }
      .gh-link svg { width: 18px; height: 18px; }

      /* ── Site footer ──────────────────────────────────────────── */
      .site-footer {
        display: flex;
        flex-direction: column;
        align-items: center;
        gap: 1.25rem;
        padding: 3.5rem 1.5rem 3rem;
        margin-top: 3rem;
        border-top: 1px solid var(--border);
        color: var(--muted);
        font-size: 0.875rem;
      }
      .footer-links {
        display: flex;
        flex-wrap: wrap;
        align-items: center;
        justify-content: center;
        column-gap: 1rem;
        row-gap: 0.5rem;
      }
      .footer-links a {
        color: var(--muted);
        text-decoration: none;
        transition: color 0.2s;
      }
      .footer-links a:hover { color: #ffffff; text-decoration: none; }
      .footer-links.secondary { font-size: 0.75rem; }
      .footer-links.secondary a { color: rgba(245, 251, 250, 0.4); }
      .footer-links.secondary a:hover { color: var(--muted); }
      .footer-sep { color: rgba(245, 251, 250, 0.35); }
      .footer-logo {
        display: inline-block;
        opacity: 0.9;
        transition: opacity 0.2s;
      }
      .footer-logo:hover { opacity: 1; }
      .footer-logo img { width: 48px; height: 48px; display: block; }
      .link-underline { position: relative; display: inline-block; }
      .link-underline::after {
        content: "";
        position: absolute;
        width: 0;
        height: 1px;
        bottom: -2px;
        left: 0;
        background-color: currentColor;
        transition: width 250ms ease;
      }
      .link-underline:hover::after { width: 100%; }

      @media (max-width: 560px) {
        .site-header { padding: 1.1rem 1.25rem; }
        .brand-name { font-size: 1.2rem; }
        .gh-link span { display: none; }
      }
    </style>
  </body>
</html>
